rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'name', 'nickname', 'avatar', 'bio', 'isOnline', 'lastSeen']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             data.nickname is string && data.nickname.size() > 0 && data.nickname.size() <= 30 &&
             data.avatar is string && data.avatar.size() <= 500 &&
             data.bio is string && data.bio.size() <= 200 &&
             data.isOnline is bool &&
             data.lastSeen is timestamp;
    }

    function isValidChat(data) {
      return hasOnlyAllowedFields(['participants', 'lastMessage', 'lastMessageTime', 'typing']) &&
             data.participants is list && data.participants.size() == 2 &&
             data.participants[0] is string && data.participants[1] is string &&
             data.lastMessage is string && data.lastMessage.size() <= 1000 &&
             data.lastMessageTime is timestamp &&
             (!('typing' in data) || data.typing is map);
    }

    function isValidMessage(data) {
      return hasOnlyAllowedFields(['senderId', 'text', 'timestamp']) &&
             data.senderId is string && data.senderId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified();
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants && isValidChat(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants && isValidChat(request.resource.data) &&
                    request.resource.data.participants == resource.data.participants; // Participants cannot be changed
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && 
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && 
                      isValidMessage(request.resource.data);
        allow update, delete: if false; // Messages are immutable
      }
    }
  }
}
