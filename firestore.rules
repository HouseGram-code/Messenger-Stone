rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'name', 'nickname', 'avatar', 'bio', 'isOnline', 'lastSeen', 'balance', 'blockedUsers', 'lastSeenPrivacy']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             data.nickname is string && data.nickname.size() > 0 && data.nickname.size() <= 30 &&
             data.avatar is string && data.avatar.size() <= 200000 &&
             data.bio is string && data.bio.size() <= 200 &&
             data.isOnline is bool &&
             data.lastSeen is timestamp &&
             (!('balance' in data) || data.balance is number) &&
             (!('blockedUsers' in data) || data.blockedUsers is list) &&
             (!('lastSeenPrivacy' in data) || data.lastSeenPrivacy in ['everyone', 'nobody']);
    }

    function isValidChat(data) {
      return hasOnlyAllowedFields(['participants', 'lastMessage', 'lastMessageTime', 'typing', 'unreadCount', 'deletedFor']) &&
             data.participants is list && data.participants.size() == 2 &&
             data.participants[0] is string && data.participants[1] is string &&
             data.lastMessage is string && data.lastMessage.size() <= 1000 &&
             data.lastMessageTime is timestamp &&
             (!('typing' in data) || data.typing is map) &&
             (!('unreadCount' in data) || data.unreadCount is map) &&
             (!('deletedFor' in data) || data.deletedFor is list);
    }

    function isValidMessage(data) {
      return hasOnlyAllowedFields(['senderId', 'text', 'timestamp', 'isEdited', 'isDeleted', 'deletedFor', 'type', 'poll', 'fileUrl', 'fileName', 'fileSize']) &&
             data.senderId is string &&
             data.text is string && data.text.size() >= 0 && data.text.size() <= 1000 &&
             data.timestamp is timestamp &&
             (!('isEdited' in data) || data.isEdited is bool) &&
             (!('isDeleted' in data) || data.isDeleted is bool) &&
             (!('deletedFor' in data) || data.deletedFor is list) &&
             (!('type' in data) || data.type in ['text', 'poll', 'image', 'video', 'audio', 'file', 'sticker', 'gif']) &&
             (!('poll' in data) || data.poll is map) &&
             (!('fileUrl' in data) || data.fileUrl is string) &&
             (!('fileName' in data) || data.fileName is string) &&
             (!('fileSize' in data) || data.fileSize is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.uid == userId && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data) && uidNotModified();
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants && isValidChat(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants && isValidChat(request.resource.data);
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && isValidMessage(request.resource.data) && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && isValidMessage(request.resource.data);
        allow delete: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
